<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.masroofy.controller.HistoryController"
            prefWidth="1000" prefHeight="680"
            style="-fx-background-color:#0F1923;">

    <top>
        <VBox>
            <!-- Nav Bar -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color:#0A1118;-fx-border-color:transparent transparent #1E3A4A transparent;-fx-border-width:0 0 1 0;-fx-padding:14 24;">
                <Label text="Masroofy"
                       style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#E8F4F8;"/>
                <Label text="●" style="-fx-text-fill:#3498DB;-fx-font-size:20px;"/>
                <Label text="/ History"
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Back" onAction="#onBackClick"
                        style="-fx-background-color:transparent;-fx-text-fill:#7BAFC4;-fx-cursor:hand;-fx-font-size:13px;-fx-padding:6 14;-fx-background-radius:20px;"/>
            </HBox>

            <!-- Filter Bar -->
            <HBox spacing="14" alignment="CENTER_LEFT"
                  style="-fx-background-color:#0A1118;-fx-border-color:transparent transparent #1E3A4A transparent;-fx-border-width:0 0 1 0;-fx-padding:12 20;">
                <Label text="FILTER:"
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:11px;"/>
                <ChoiceBox fx:id="cbFilter" prefWidth="155" prefHeight="34"/>
                <Label text="FROM"
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:11px;"/>
                <DatePicker fx:id="dpFrom" prefWidth="145" prefHeight="34"/>
                <Label text="TO"
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:11px;"/>
                <DatePicker fx:id="dpTo" prefWidth="145" prefHeight="34"/>
                <Button text="Apply" onAction="#onApplyFilterClick"
                        style="-fx-background-color:#2A86B5;-fx-text-fill:white;-fx-cursor:hand;-fx-background-radius:6px;-fx-padding:6 18;-fx-font-size:12px;"/>
                <Button text="Clear" onAction="#onClearFilterClick"
                        style="-fx-background-color:#1E3A4A;-fx-text-fill:#7BAFC4;-fx-cursor:hand;-fx-background-radius:6px;-fx-border-color:#2D5A72;-fx-border-radius:6px;-fx-padding:6 14;-fx-font-size:12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTxCount" text=""
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:12px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding:16 20;-fx-background-color:#0F1923;">
            <!-- Action buttons for selected transaction -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="✎ Edit" onAction="#onEditClick"
                        style="-fx-background-color:#2A86B5;-fx-text-fill:white;-fx-cursor:hand;-fx-background-radius:6px;-fx-padding:6 16;-fx-font-size:12px;"/>
                <Button text="🗑 Delete" onAction="#onDeleteClick"
                        style="-fx-background-color:#E74C3C;-fx-text-fill:white;-fx-cursor:hand;-fx-background-radius:6px;-fx-padding:6 16;-fx-font-size:12px;"/>
                <Label text="Select a transaction to edit or delete"
                       style="-fx-text-fill:#4E7A8E;-fx-font-size:12px;-fx-padding:0 0 0 10;"/>
            </HBox>
            <StackPane VBox.vgrow="ALWAYS">
                <ListView fx:id="listTransactions"
                          style="-fx-background-color:transparent;-fx-border-color:transparent;"/>
                <Label fx:id="lblNoTransactions"
                       text="No transactions found."
                       style="-fx-text-fill:#2D5A72;-fx-font-size:15px;-fx-padding:50;"
                       visible="false" StackPane.alignment="CENTER"/>
            </StackPane>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="32"
              style="-fx-background-color:#0A1118;-fx-padding:12 24;-fx-border-color:#1E3A4A transparent transparent transparent;-fx-border-width:1 0 0 0;">
            <VBox spacing="2">
                <Label text="TOTAL SHOWN"
                       style="-fx-font-size:11px;-fx-text-fill:#4E7A8E;"/>
                <Label fx:id="lblTotalShown" text="EGP 0.00"
                       style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#E8F4F8;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
