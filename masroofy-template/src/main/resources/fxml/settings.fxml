<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.masroofy.controller.SettingsController"
            prefWidth="600" prefHeight="500"
            style="-fx-background-color:#0F1923;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:#0A1118;-fx-border-color:transparent transparent #1E3A4A transparent;-fx-border-width:0 0 1 0;-fx-padding:14 24;">
            <Label text="Masroofy"
                   style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#E8F4F8;"/>
            <Label text="●" style="-fx-text-fill:#3498DB;-fx-font-size:20px;"/>
            <Label text="/ Settings"
                   style="-fx-text-fill:#4E7A8E;-fx-font-size:14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back" onAction="#onBackClick"
                    style="-fx-background-color:transparent;-fx-text-fill:#7BAFC4;-fx-cursor:hand;-fx-font-size:13px;-fx-padding:6 14;-fx-background-radius:20px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" alignment="TOP_CENTER"
              style="-fx-padding:32 40;-fx-background-color:#0F1923;">

            <!-- Privacy Lock Section -->
            <VBox spacing="12" alignment="TOP_LEFT"
                  style="-fx-background-color:#142230;-fx-border-color:#1E3A4A;-fx-border-width:1px;-fx-border-radius:12px;-fx-background-radius:12px;-fx-padding:24;">

                <Label text="🔒 Privacy Lock (US#12)"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#E8F4F8;"/>

                <Label text="Enable a PIN lock to protect your financial data when others access your device."
                       style="-fx-font-size:12px;-fx-text-fill:#7BAFC4;"
                       wrapText="true"/>

                <Region prefHeight="8"/>

                <!-- Enable/Disable Toggle -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <CheckBox fx:id="chkPrivacyLock" text="Enable Privacy Lock"
                              onAction="#onPrivacyLockToggle"
                              style="-fx-text-fill:#E8F4F8;-fx-font-size:14px;"/>
                </HBox>

                <!-- PIN Setup (shown when enabled) -->
                <VBox fx:id="pinSetupBox" spacing="12" visible="false">
                    <Region prefHeight="8"/>
                    <Label text="Set your 4-6 digit PIN:"
                           style="-fx-font-size:12px;-fx-text-fill:#4E7A8E;"/>
                    <HBox spacing="12">
                        <PasswordField fx:id="txtPin" promptText="Enter PIN"
                                       prefWidth="150" prefHeight="36"
                                       style="-fx-background-color:#0F1923;-fx-text-fill:#E8F4F8;-fx-prompt-text-fill:#4E7A8E;-fx-border-color:#1E3A4A;-fx-border-radius:6px;"/>
                        <PasswordField fx:id="txtConfirmPin" promptText="Confirm PIN"
                                       prefWidth="150" prefHeight="36"
                                       style="-fx-background-color:#0F1923;-fx-text-fill:#E8F4F8;-fx-prompt-text-fill:#4E7A8E;-fx-border-color:#1E3A4A;-fx-border-radius:6px;"/>
                    </HBox>
                    <Label fx:id="lblPinStatus" text=""
                           style="-fx-font-size:12px;-fx-text-fill:#E74C3C;"/>
                    <Button text="Save PIN" onAction="#onSavePinClick"
                            prefWidth="120" prefHeight="36"
                            style="-fx-background-color:#2A86B5;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:6px;-fx-cursor:hand;"/>
                </VBox>

                <!-- Lock Status -->
                <Label fx:id="lblLockStatus" text="Privacy Lock: Disabled"
                       style="-fx-font-size:12px;-fx-text-fill:#4E7A8E;"/>
            </VBox>

            <!-- About Section -->
            <VBox spacing="8" alignment="TOP_LEFT"
                  style="-fx-background-color:#142230;-fx-border-color:#1E3A4A;-fx-border-width:1px;-fx-border-radius:12px;-fx-background-radius:12px;-fx-padding:24;">
                <Label text="About Masroofy"
                       style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#E8F4F8;"/>
                <Label text="Masroofy v1.0 - Budget Management for College Students"
                       style="-fx-font-size:12px;-fx-text-fill:#7BAFC4;"/>
                <Label text="© 2026 CS251 Software Engineering Project"
                       style="-fx-font-size:11px;-fx-text-fill:#4E7A8E;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
